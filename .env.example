# ─────────────────────────────────────────────
# Audio Customer Support Agent — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────

# OpenAI API key (required for LLM)
OPENAI_API_KEY=your_openai_key_here

# Whisper model size: tiny | base | small | medium | large
# 'base' is the best balance of speed and accuracy for most use cases
STT_MODEL=base

# Microsoft Edge TTS voice
TTS_VOICE=en-US-AriaNeural

# Directory where ChromaDB stores its persistent data
CHROMA_PERSIST_DIR=./chroma_db

# OpenAI model for the LLM agent
LLM_MODEL=gpt-3.5-turbo

# LLM sampling temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7
